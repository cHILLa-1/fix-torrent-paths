export QBIT_HOST=IP:PORT
export QBIT_USER=USERNAME
export QBIT_PASS=PASSWORD
export QBIT_CONTAINER_ROOT=/data/torrents
export QBIT_LOCAL_ROOT=/mnt/data/torrents

# Completely ignore cross-seed torrents (/data/cross-seed/...) - these are
# never touched, regardless of which category they are assigned to.
export QBIT_SKIP_SOURCE_PREFIXES="e.g. /data/cross-seed"

# Additional local folder (not a container path, directly local!), which is
# scanned for known torrent contents. Anything in it that matches a
# qBittorrent torrent by name is moved into the folder belonging to that
# category (larger file wins on conflict) and then rechecked.
export QBIT_EXTRA_SCAN_DIRS="e.g. /mnt/data/torrents/orphaned_data"
